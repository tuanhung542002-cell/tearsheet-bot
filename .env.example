# ── Required ─────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── FiinGate login (needed for private company lookups) ───────────
FIINGATE_EMAIL=your_fiingate_email@example.com
FIINGATE_PASSWORD=your_fiingate_password

# ── Optional ──────────────────────────────────────────────────────
# Comma-separated Telegram chat IDs allowed to use the bot
# Leave blank to allow anyone who messages it
ALLOWED_CHAT_IDS=

# USD/VND conversion rate (default 26500)
USD_VND_RATE=26500

# Path to save FiinGate session cookies (avoids re-login every time)
FIINGATE_SESSION_FILE=/tmp/fiingate_session.json
